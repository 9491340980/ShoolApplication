rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isSuper() { return signedIn() && me().role == 'superadmin'; }
    function isHM() { return signedIn() && me().role == 'headmaster'; }
    function isStaff() { return signedIn() && me().role in ['headmaster', 'teacher']; }
    function sameSchool() { return signedIn() && resource.data.schoolId == me().schoolId; }
    function writingOwnSchool() { return signedIn() && request.resource.data.schoolId == me().schoolId; }

    match /schools/{id} {
      allow read: if signedIn();
      allow create, delete: if isSuper();
      // Super admin can change anything; a Head Master may update only their own
      // school's logo (branding) — not adminEmail, active status, etc.
      allow update: if isSuper()
        || (isHM() && id == me().schoolId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['logo']));
    }
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuper() || (isHM() && resource.data.schoolId == me().schoolId));
      allow create: if signedIn() && (request.auth.uid == uid || isSuper() || (isHM() && request.resource.data.schoolId == me().schoolId));
      allow update: if signedIn() && (request.auth.uid == uid || isSuper() || (isHM() && resource.data.schoolId == me().schoolId));
      allow delete: if isSuper() || (isHM() && sameSchool());
    }
    match /students/{id}   {
      allow read: if sameSchool() || isSuper();
      allow create: if isHM() && writingOwnSchool();
      // HM edits anything; any staff may set only the parent-link token.
      allow update: if (isHM() && writingOwnSchool())
        || (isStaff() && sameSchool() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shareToken']));
      allow delete: if isHM() && sameSchool();
    }
    // Passwordless parent-view links: openable by anyone who has the unguessable
    // token (get by id only — never listable), writable by the school's staff.
    match /shares/{token} {
      allow get: if true;
      allow list: if false;
      allow write: if isStaff() && request.resource.data.schoolId == me().schoolId;
    }
    match /teachers/{id}   { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /timetables/{id} { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /subjects/{id}   { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /classesList/{id} { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /examsList/{id}   { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /fees/{id}       { allow read: if sameSchool() || isSuper(); allow create, update: if isHM() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /attendance/{id} { allow read: if sameSchool() || isSuper(); allow create, update: if isStaff() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /marks/{id}      { allow read: if sameSchool() || isSuper(); allow create, update: if isStaff() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /notices/{id}    { allow read: if sameSchool() || isSuper(); allow create, update: if isStaff() && writingOwnSchool(); allow delete: if isHM() && sameSchool(); }
    match /homework/{id}   { allow read: if sameSchool() || isSuper(); allow create, update: if isStaff() && writingOwnSchool(); allow delete: if isStaff() && sameSchool(); }
    // Class-teacher assignments & teacher attendance — Head Master or Super Admin managed.
    match /assignments/{id}      { allow read: if sameSchool() || isSuper(); allow create, update: if isSuper() || (isHM() && writingOwnSchool()); allow delete: if isSuper() || (isHM() && sameSchool()); }
    match /teacherAttendance/{id} {
      // Allow listening to today's doc before it exists (resource == null), else scope to own school.
      allow read: if isSuper() || (isStaff() && (resource == null || resource.data.schoolId == me().schoolId));
      allow create, update: if isSuper() || (isHM() && writingOwnSchool());
    }
  }
}
